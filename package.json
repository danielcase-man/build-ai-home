{
  "name": "ubuildit-manager",
  "version": "1.0.0",
  "description": "A comprehensive home construction management application for tracking the UBuildIt process from planning through construction.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "docs:analyze": "node scripts/analyze-documents.js",
    "docs:reorganize:dry-run": "node scripts/reorganize-documents.js --dry-run",
    "docs:reorganize": "node scripts/reorganize-documents.js --execute --preserve-originals",
    "docs:smart-classify": "node scripts/smart-document-classifier.js",
    "docs:ai-classify": "node scripts/ai-document-classifier.js",
    "docs:ai-reorganize:dry-run": "node scripts/reorganize-with-ai.js --dry-run",
    "docs:ai-reorganize": "node scripts/reorganize-with-ai.js --execute",
    "docs:extract": "node scripts/extract-to-database.js",
    "docs:extract:dry-run": "node scripts/extract-to-database.js --dry-run",
    "docs:packages": "node scripts/create-shareable-packages.js --all",
    "docs:watch": "node scripts/watch-folder.js",
    "docs:audit": "node scripts/monthly-audit.js",
    "seed": "npx tsx scripts/seed-from-docs.ts",
    "add-transactions": "npx tsx scripts/add-transactions.ts",
    "seed:selections": "npx tsx scripts/seed-selections.ts",
    "seed:bids": "npx tsx scripts/seed-bids.ts",
    "schedule:view": "start CONSTRUCTION_SCHEDULE.html",
    "schedule:edit": "start CONSTRUCTION_SCHEDULE.csv",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:all": "vitest run && npx playwright test"
  },
  "keywords": [
    "construction",
    "project-management",
    "ubuildit",
    "next.js"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.54.0",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.21",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^4.1.0",
    "date-holidays": "^3.26.8",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.0",
    "fs-extra": "^11.3.3",
    "googleapis": "^155.0.1",
    "lucide-react": "^0.539.0",
    "next": "^15.4.6",
    "openai": "^5.12.2",
    "pdf-parse-fork": "^1.2.0",
    "pdfkit": "^0.17.2",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.12",
    "vitest": "^4.0.18"
  }
}
