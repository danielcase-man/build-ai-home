{
  "functions": {
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/intelligence/**/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/project-status/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/bids/upload/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/bids/reextract/**/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/coverage/**/*.ts": {
      "maxDuration": 120
    },
    "src/app/api/assistant/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/orchestrator",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sync-jobtread",
      "schedule": "55 7 * * *"
    },
    {
      "path": "/api/cron/sync-emails",
      "schedule": "0 8,12,16,20 * * *"
    },
    {
      "path": "/api/intelligence/run?sources=dropbox&backlog=true",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/coverage/pipeline?force=false",
      "schedule": "0 9,14,19 * * *"
    },
    {
      "path": "/api/bids/reextract?all=true",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron/daily-status",
      "schedule": "0 23 * * *"
    }
  ]
}
