{
  "name": "FrameWork",
  "short_name": "FrameWork",
  "description": "Construction project management — budget, bids, vendors, and build tracking",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0C0A09",
  "theme_color": "#F97316",
  "orientation": "any",
  "categories": ["business", "productivity"],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "url": "/dashboard",
      "description": "View project dashboard"
    },
    {
      "name": "Job Site",
      "short_name": "Job Site",
      "url": "/job-site",
      "description": "Job site management and updates"
    },
    {
      "name": "Vendor Research",
      "short_name": "Vendors",
      "url": "/vendor-research",
      "description": "Research and compare vendors"
    },
    {
      "name": "Compliance",
      "short_name": "Compliance",
      "url": "/compliance",
      "description": "Permits and regulatory compliance"
    }
  ],
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"]
      }
    }
  ]
}
